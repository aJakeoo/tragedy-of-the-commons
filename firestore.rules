rules_version = '2';

// Tragedy of the Comments - no auth, room-code-gated by obscurity only.
// Anyone with a room's 4-character code can read/write everything nested
// under that room (players, rounds, submissions, ballots) - acceptable for
// a live, host-supervised party game with no accounts. Everything else is
// denied by default.
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{code} {
      allow read, write: if true;
    }
    match /rooms/{code}/{document=**} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
